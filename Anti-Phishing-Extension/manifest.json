{
  "manifest_version": 3,
  "name": "Anti-Phishing Demo Extension",
  "version": "1.0",
  "description": "Detects basic phishing indicators such as IP-based URLs.",
  "permissions": ["tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
